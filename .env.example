# ─────────────────────────────────────────────────────────────
# Finance Tracker Pro — environment variables
# Copy to `.env` (local) and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# --- Database (PostgreSQL) ---------------------------------------------------
# Runtime connection (pooled in production, e.g. PgBouncer / Prisma Accelerate).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance_tracker?schema=public"
# Direct, unpooled connection used by `prisma migrate`. Same as DATABASE_URL for local dev.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/finance_tracker?schema=public"

# --- Auth.js -----------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# Canonical URL of the app (used for callbacks). Required in production.
AUTH_URL="http://localhost:3000"
# Trust the host header behind a proxy/in containers.
AUTH_TRUST_HOST="true"

# --- OAuth providers (optional) ----------------------------------------------
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- Email (verification / password reset) -----------------------------------
# SMTP transport for transactional email. Leave blank to disable email flows in dev.
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="Finance Tracker Pro <no-reply@example.com>"

# --- App ---------------------------------------------------------------------
# "development" | "test" | "production"
NODE_ENV="development"
